name = "deaubit"
main = "src/index.ts"
compatibility_date = "2025-04-01"
compatibility_flags = ["nodejs_compat"]
workers_dev = false
preview_urls = false

[assets]
directory = "../out"
binding = "ASSETS"
not_found_handling = "none"

[[d1_databases]]
binding = "DB"
database_name = "deaubit-db"
database_id = "PLACEHOLDER_DB_ID"
migrations_dir = "migrations"

[[kv_namespaces]]
binding = "SESSION"
id = "PLACEHOLDER_KV_ID"

[vars]
APP_HOST = "PLACEHOLDER_APP_HOST"
PROTOCOL = "https"
SHORT_HOST = "PLACEHOLDER_SHORT_HOST"
TURNSTILE_SITE_KEY = "PLACEHOLDER_TURNSTILE_SITE_KEY"
MAIL_FROM = "PLACEHOLDER_MAIL_FROM"
MAIL_FROM_NAME = "DeauBit"

[triggers]
crons = ["0 3 * * *"]
