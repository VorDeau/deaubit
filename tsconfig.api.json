{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["src/api"],
  "exclude": ["node_modules"]
}
